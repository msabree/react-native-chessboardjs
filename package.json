{
  "name": "react-native-chessboardjs",
  "version": "0.4.1",
  "description": "A chessboard library for react-native.",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace react-native-chessboardjs-example",
    "test": "jest --coverage  ",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli lib",
    "prepare": "bob build",
    "release": "release-it"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": "https://github.com/msabree/react-native-chessboardjs",
  "author": "Makeen Sabree <makeen.sabree@gmail.com> (https://github.com/msabree)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/msabree/react-native-chessboardjs/issues"
  },
  "homepage": "https://github.com/msabree/react-native-chessboardjs#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@mgcrea/react-native-dnd": "^2.5.3",
    "react-native-gesture-handler": "^2.24.0",
    "react-native-reanimated": "^3.17.0",
    "react-native-svg": "^15.11.0"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.0.0",
    "@evilmartians/lefthook": "^1.5.0",
    "@react-native/eslint-config": "^0.76.0",
    "@release-it/conventional-changelog": "^5.0.0",
    "@testing-library/jest-native": "^5.4.3",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.0.0",
    "@types/react-native": "^0.73.0",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.7.0",
    "commitlint": "^19.0.0",
    "del-cli": "^5.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "react": "19.0.0",
    "react-native": "0.79.1",
    "react-native-builder-bob": "^0.23.0",
    "react-test-renderer": "19.0.0",
    "release-it": "^17.0.0",
    "typescript": "~5.8.0"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "workspaces": [
    "example"
  ],
  "compilerOptions": {
    "typeRoots": [
      "src/@types",
      "node_modules/@types"
    ]
  },
  "packageManager": "yarn@3.6.1",
  "engines": {
    "node": ">=16"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular"
      }
    }
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native",
      "prettier"
    ],
    "rules": {
      "prettier/prettier": [
        "error",
        {
          "quoteProps": "consistent",
          "singleQuote": true,
          "tabWidth": 2,
          "trailingComma": "es5",
          "useTabs": false
        }
      ]
    }
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/",
    "src/chessboard-lib/"
  ],
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
